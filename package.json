{
  "name": "save-serve-custom",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Custom Save&Serve platform rebuild without Base44 runtime dependencies.",
  "scripts": {
    "backend:build": "npm run api:build && npm run worker:build",
    "api:build": "npm --prefix apps/api run build",
    "api:start": "npm --prefix apps/api run start",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:seed": "node scripts/db-seed-demo.mjs",
    "test:integration": "node tests/integration/marketplace-smoke.mjs",
    "web:build": "npm --prefix apps/web run build",
    "web:dev": "npm --prefix apps/web run dev",
    "worker:build": "npm --prefix apps/worker run build",
    "worker:start": "npm --prefix apps/worker run start"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "@types/pg": "^8.20.0",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "pg": "^8.20.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^6.1.0"
  }
}
